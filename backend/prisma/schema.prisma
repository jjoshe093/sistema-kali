// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// schema.prisma
model Producto {
  id             Int             @id @default(autoincrement())
  nombre         String
  precio         Float
  stock          Int             @default(0)
  esComida       Boolean         @default(false)
  categoria      String          @default("Bebidas") // <--- Añade esta línea
  esCerveza   	 Boolean  	 @default(false) // <--- NUEVO CAMPO
  detallesPedido DetallePedido[]
}

model Pedido {
  id             Int             @id @default(autoincrement())
  mesero         String
  fecha          DateTime        @default(now())
  total          Float           @default(0)
  estado         String          @default("ABIERTO") // "ABIERTO" o "CERRADO"
  detallesPedido DetallePedido[]
}

model DetallePedido {
  id               Int      @id @default(autoincrement())
  pedidoId         Int
  productoId       Int      // Aquí irá el ID de la "Michelada" ($4.50)
  productoBaseId   Int?     // Aquí guardaremos el ID de la cerveza para el stock
  nombrePersonalizado String? // Para guardar "Michelada con Regia Alta"
  cantidad         Int
  pedido           Pedido   @relation(fields: [pedidoId], references: [id])
  producto         Producto @relation(fields: [productoId], references: [id])
}
